    if (caNotes) {
      if (y > 230) { pdfFooter(doc, doc.getNumberOfPages(), '?'); doc.addPage(); y = 14; }
      y = sectionHeading(doc, 'CA Notes for Doctor', y);
      doc.setFillColor(...PDF.BG);
      const noteLines = doc.splitTextToSize(caNotes, PDF.W - 8);
      doc.rect(PDF.L, y, PDF.W, noteLines.length * 5 + 6, 'F');
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(8);
      doc.setTextColor(...PDF.DARK);
      doc.text(noteLines, PDF.L + 4, y + 5);
      y += noteLines.length * 5 + 10;
    }

    const total = doc.getNumberOfPages();
    for (let i = 1; i <= total; i++) { doc.setPage(i); pdfFooter(doc, i, total); }

    doc.save(`${fname}_PE1_FullReport.pdf`);
  }

  async function submitAll() {
    if (typeof window.jspdf === 'undefined') {
      alert('PDF library not loaded. Please refresh and try again.');
      return;
    }

    const btn = document.getElementById('submitBtn');
    btn.disabled    = true;
    btn.textContent = 'Generating PDFs...';

    const fname = (contactName || 'Patient').replace(/\s+/g, '_');

    try {
      const q = collectQuestionnaire();
      const r = collectROMStructured();

      buildQuestionnairePDF(q, fname);
      await new Promise(res => setTimeout(res, 400));
      buildFullReportPDF(q, r, fname);

      btn.textContent = 'Sending to GHL...';
      const success = await sendToGHL({
        contact_name:      contactName,
        contact_email:     contactEmail,
        exam_number:       'Progress Exam 1',
        current_balance:   r.curBal,
        experience_rating: q.stars,
        rom_note:          r.note,
        submitted_at:      new Date().toISOString()
      });

      btn.textContent      = success ? '✓ PDFs Saved & Sent to GHL' : '⚠ PDFs saved — GHL sync failed';
      btn.style.background = success ? '#16a34a' : '#dc2626';
      setTimeout(() => { btn.textContent = 'Generate PDF & Send to GHL'; btn.style.background = ''; btn.disabled = false; }, 5000);

    } catch(err) {
      console.error(err);
      alert('Error generating PDFs. Please try again.');
      btn.textContent = 'Generate PDF & Send to GHL';
      btn.disabled    = false;
    }
  }

  // ── Init ──
  document.addEventListener('DOMContentLoaded', () => {
    handleUrlAutofill();
    updateProgress();
    document.querySelectorAll('.check-item input[type="checkbox"]').forEach(cb => {
      cb.addEventListener('click', e => e.stopPropagation());
    });
  });
</script>
