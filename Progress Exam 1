<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Progress Exam 1 — Well Adjusted Chiropractic</title>
  <style>
    :root {
      --bg: #f6f7fb;
      --card: #ffffff;
      --ink: #1f2937;
      --muted: #6b7280;
      --line: #e5e7eb;
      --accent: #D1B37D;
      --accent-dark: #b8964f;
      --shadow: 0 2px 10px rgba(0,0,0,.06);
      --radius: 14px;
      --green: #16a34a;
      --red: #dc2626;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Arial, sans-serif;
      color: var(--ink);
      background: var(--bg);
      padding: 18px;
      position: relative;
    }

    /* Watermark */
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      margin: auto;
      width: 480px;
      height: 480px;
      background: url('https://assets.cdn.filesafe.space/Hoy53z3hkBCQoCR1ayzn/media/6993c00a8ef1b98a1834ffb3.jpeg') no-repeat center;
      background-size: contain;
      opacity: 0.06;
      pointer-events: none;
      z-index: 0;
    }

    .wrap {
      max-width: 780px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    /* ── Phase indicator ── */
    .phase-indicator {
      display: flex;
      align-items: center;
      gap: 0;
      margin-bottom: 20px;
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
    }

    .phase-step {
      flex: 1;
      padding: 13px 16px;
      font-size: 13px;
      font-weight: 600;
      color: var(--muted);
      text-align: center;
      border-right: 1px solid var(--line);
      position: relative;
      transition: all .3s;
    }

    .phase-step:last-child { border-right: none; }

    .phase-step.active {
      background: var(--accent);
      color: #fff;
    }

    .phase-step.done {
      background: #f0fdf4;
      color: var(--green);
    }

    .phase-step .step-num {
      display: block;
      font-size: 11px;
      font-weight: 400;
      opacity: .8;
      margin-bottom: 2px;
    }

    /* ── Header banner ── */
    .header-banner {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 18px 22px;
      margin-bottom: 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
    }

    .header-banner img { height: 36px; }

    .header-right {
      font-size: 13px;
      color: var(--muted);
      text-align: right;
      line-height: 1.6;
    }

    .header-right strong { color: var(--ink); }

    /* ── Patient data cards ── */
    .data-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 10px;
      margin-bottom: 16px;
    }

    .data-card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 11px 14px;
      box-shadow: var(--shadow);
    }

    .data-card .lbl {
      font-size: 10px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .6px;
      margin-bottom: 3px;
    }

    .data-card .val {
      font-size: 14px;
      font-weight: 700;
      color: var(--ink);
    }

    .data-card .val.accent { color: var(--accent-dark); }

    /* ── Cards ── */
    section {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 18px;
      margin-bottom: 14px;
    }

    h2 {
      font-size: 15px;
      color: var(--accent);
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    /* ── Questions ── */
    .question-block {
      margin-bottom: 20px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--line);
    }

    .question-block:last-child {
      margin-bottom: 0;
      padding-bottom: 0;
      border-bottom: none;
    }

    .q-label {
      font-size: 14px;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 10px;
      line-height: 1.4;
    }

    .q-num {
      display: inline-block;
      width: 24px;
      height: 24px;
      background: var(--accent);
      color: #fff;
      border-radius: 50%;
      font-size: 12px;
      font-weight: 700;
      text-align: center;
      line-height: 24px;
      margin-right: 8px;
      flex-shrink: 0;
    }

    /* Radio + Checkbox options */
    .options-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .option-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      border: 1px solid var(--line);
      border-radius: 10px;
      cursor: pointer;
      font-size: 14px;
      transition: background .15s, border-color .15s;
      background: #fafbfc;
    }

    .option-item:hover { background: #f0f4ff; border-color: #c7d2fe; }

    .option-item.selected {
      background: #fffbeb;
      border-color: var(--accent);
    }

    .option-item input[type="radio"],
    .option-item input[type="checkbox"] {
      width: 16px;
      height: 16px;
      accent-color: var(--accent);
      cursor: pointer;
      flex-shrink: 0;
    }

    /* Star rating */
    .star-row {
      display: flex;
      gap: 10px;
      margin-top: 4px;
    }

    .star-btn {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      border: 2px solid var(--line);
      background: #fafbfc;
      font-size: 22px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all .15s;
    }

    .star-btn:hover { border-color: var(--accent); background: #fffbeb; }
    .star-btn.selected { border-color: var(--accent); background: #fffbeb; }

    .star-label {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      color: var(--muted);
      margin-top: 6px;
      padding: 0 2px;
    }

    /* Text inputs */
    input[type="text"],
    input[type="number"],
    textarea,
    select {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 10px 12px;
      font-size: 14px;
      outline: none;
      background: #fff;
      font-family: Arial, sans-serif;
      color: var(--ink);
    }

    input:focus, textarea:focus, select:focus { border-color: var(--accent); }
    textarea { min-height: 88px; resize: vertical; }

    /* Open text field within checkbox */
    .option-open-input {
      margin-top: 8px;
      display: none;
    }
    .option-item.selected .option-open-input { display: block; }

    /* ── Checklist (CA section) ── */
    .checklist { display: flex; flex-direction: column; gap: 8px; }

    .check-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 10px 14px;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: #fafbfc;
      cursor: pointer;
      font-size: 14px;
      line-height: 1.4;
      transition: background .15s, border-color .15s;
    }

    .check-item:hover { background: #f0f4ff; border-color: #c7d2fe; }
    .check-item.checked { background: #f0fdf4; border-color: #86efac; }
    .check-item.flag-item { border-left: 3px solid var(--accent); }
    .check-item.flag-item.flagged { background: #fff7ed; border-color: #fbbf24; border-left-color: var(--red); }

    .check-item input[type="checkbox"] {
      width: 17px;
      height: 17px;
      accent-color: var(--accent);
      cursor: pointer;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .check-item label {
      cursor: pointer;
      color: var(--ink);
      font-size: 14px;
      display: block;
      margin: 0;
    }

    .check-item .sub-label {
      font-size: 12px;
      color: var(--muted);
      margin-top: 2px;
    }

    /* ── ROM Table ── */
    .rom-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }

    .rom-table th {
      text-align: left;
      padding: 8px 10px;
      border-bottom: 2px solid var(--line);
      color: var(--muted);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: .5px;
    }

    .rom-table td {
      padding: 7px 10px;
      border-bottom: 1px solid var(--line);
      vertical-align: middle;
    }

    .rom-table tr:last-child td { border-bottom: none; }
    .rom-normal { font-weight: 600; color: var(--muted); }

    .rom-table input[type="number"] {
      width: 65px;
      padding: 5px 8px;
      border: 1px solid var(--line);
      border-radius: 8px;
      font-size: 13px;
    }

    .rom-table input[type="text"] {
      padding: 5px 8px;
      border: 1px solid var(--line);
      border-radius: 8px;
      font-size: 13px;
    }

    .section-divider {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .8px;
      color: var(--muted);
      margin: 14px 0 8px;
      padding-bottom: 5px;
      border-bottom: 1px solid var(--line);
    }

    /* ── Progress bar ── */
    .progress-wrap { margin-bottom: 16px; }
    .progress-bar-bg { height: 5px; background: var(--line); border-radius: 99px; overflow: hidden; }
    .progress-bar-fill { height: 100%; background: var(--accent); border-radius: 99px; width: 0%; transition: width .3s; }
    .progress-lbl { font-size: 12px; color: var(--muted); margin-bottom: 5px; display: flex; justify-content: space-between; }

    /* ── Internal badge ── */
    .internal-badge {
      display: inline-block;
      font-size: 11px;
      background: #fef3c7;
      color: #92400e;
      border: 1px solid #fde68a;
      border-radius: 6px;
      padding: 2px 8px;
      font-weight: 600;
    }

    /* ── Buttons ── */
    .btn-primary {
      height: 44px;
      padding: 0 26px;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      font-family: Arial, sans-serif;
      transition: .2s;
    }

    .btn-primary:hover { filter: brightness(.92); }

    .btn-secondary {
      height: 44px;
      padding: 0 20px;
      background: #fff;
      color: var(--ink);
      border: 1px solid var(--line);
      border-radius: 10px;
      font-size: 14px;
      cursor: pointer;
      font-family: Arial, sans-serif;
    }

    .action-row {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
      margin-top: 6px;
      margin-bottom: 30px;
    }

    /* ── Phase visibility ── */
    .phase-patient { display: block; }
    .phase-review  { display: none;  }
    .phase-ca      { display: none;  }

    body.review-phase .phase-patient { display: none; }
    body.review-phase .phase-review  { display: block; }
    body.review-phase .phase-ca      { display: none; }

    body.ca-phase .phase-patient { display: none; }
    body.ca-phase .phase-review  { display: none; }
    body.ca-phase .phase-ca      { display: block; }

    /* ── Review page styles ── */
    .review-card {
      background: var(--card);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 18px 22px;
      margin-bottom: 14px;
    }
    .review-q {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 4px;
      font-weight: 600;
      letter-spacing: .2px;
    }
    .review-a {
      font-size: 15px;
      font-weight: 700;
      color: var(--ink);
    }
    .review-a.flagged-ans {
      color: var(--red);
    }
    .flag-banner {
      background: #fff0f0;
      border: 1.5px solid var(--red);
      border-radius: var(--radius);
      padding: 14px 18px;
      margin-bottom: 14px;
    }
    .flag-banner .flag-title {
      font-size: 13px;
      font-weight: 700;
      color: var(--red);
      text-transform: uppercase;
      letter-spacing: .5px;
      margin-bottom: 8px;
    }
    .flag-row {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      margin-bottom: 6px;
      font-size: 13px;
      color: var(--red);
    }
    .flag-row .flag-icon { font-size: 15px; flex-shrink: 0; }
    .google-banner {
      background: linear-gradient(135deg, #e8f5e9, #f1f8e9);
      border: 1.5px solid #4caf50;
      border-radius: var(--radius);
      padding: 14px 18px;
      margin-bottom: 14px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .google-banner .g-icon { font-size: 28px; }
    .google-banner .g-text { font-size: 14px; font-weight: 700; color: #2e7d32; }
    .google-banner .g-sub  { font-size: 12px; color: #388e3c; margin-top: 2px; }
    .review-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 14px;
    }
    @media (max-width: 540px) { .review-grid { grid-template-columns: 1fr; } }

    /* ── PDF mode ── */
    .pdfMode .no-print   { display: none !important; }
    .notes-print {
      display: none;
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 10px 12px;
      font-size: 14px;
      background: #fff;
      white-space: pre-wrap;
      min-height: 80px;
    }
    .pdfMode .notes-print  { display: block; }
    .pdfMode .notes-input  { display: none; }
    .pdfMode .phase-indicator { display: none; }

    /* In PDF mode show both phases */
    .pdfMode .phase-patient { display: block !important; }
    .pdfMode .phase-ca      { display: block !important; }

    /* PDF section break label */
    .pdf-section-label {
      display: none;
      background: var(--accent);
      color: #fff;
      font-size: 13px;
      font-weight: 700;
      padding: 8px 16px;
      border-radius: 8px;
      margin-bottom: 12px;
      letter-spacing: .4px;
    }
    .pdfMode .pdf-section-label { display: block; }

    footer {
      text-align: center;
      font-size: .82em;
      color: #bbb;
      margin-top: 18px;
    }

    @media (max-width: 640px) {
      .data-grid { grid-template-columns: 1fr 1fr; }
      .header-banner { flex-direction: column; }
      .star-row { gap: 6px; }
      .star-btn { width: 40px; height: 40px; font-size: 18px; }
    }
  </style>
</head>
<body>
<div class="wrap">



  <!-- ═══════════════════════════════════════
       PHASE 1 — PATIENT QUESTIONNAIRE
  ════════════════════════════════════════ -->
  <div class="phase-patient" id="phasePatient">

    <div class="pdf-section-label">SECTION 1 — PATIENT QUESTIONNAIRE</div>

    <!-- Header -->
    <div class="header-banner">
      <img src="https://assets.cdn.filesafe.space/uUGu9qTLe0cEAC8VRMtN/media/67b51f9c32195e2c50c7b5e6.png" alt="Well Adjusted Chiropractic">
      <div class="header-right">
        <strong id="p1Name">—</strong><br>
        Progress Exam 1 &nbsp;·&nbsp; <span id="p1Date">—</span>
      </div>
    </div>

    <section>
      <h2><strong>Progress Exam 1 — Patient Questionnaire</strong></h2>

      <!-- Q1 Star Rating -->
      <div class="question-block">
        <div class="q-label"><span class="q-num">1</span>Rate your experience with Well Adjusted Chiropractic</div>
        <div class="star-row" id="starRow">
          <button type="button" class="star-btn" data-val="1" onclick="selectStar(1)">★</button>
          <button type="button" class="star-btn" data-val="2" onclick="selectStar(2)">★</button>
          <button type="button" class="star-btn" data-val="3" onclick="selectStar(3)">★</button>
          <button type="button" class="star-btn" data-val="4" onclick="selectStar(4)">★</button>
          <button type="button" class="star-btn" data-val="5" onclick="selectStar(5)">★</button>
        </div>
        <div class="star-label"><span>Not awesome</span><span>Awesome!</span></div>
        <input type="hidden" id="q1Stars" value="">
      </div>

      <!-- Q2 Health Goals -->
      <div class="question-block">
        <div class="q-label"><span class="q-num">2</span>What are your Health Goals at this point in your care?</div>
        <div class="options-list">
          <label class="option-item" onclick="toggleOption(this)">
            <input type="checkbox" name="q2" value="Correct symptoms / Body Signals">
            Correct symptoms / Body Signals
            <div class="option-open-input"><input type="text" placeholder="Describe..." onclick="event.stopPropagation()"></div>
          </label>
          <label class="option-item" onclick="toggleOption(this)">
            <input type="checkbox" name="q2" value="Improve function of body systems">
            Improve function of body systems
            <div class="option-open-input"><input type="text" placeholder="Describe..." onclick="event.stopPropagation()"></div>
          </label>
          <label class="option-item" onclick="toggleOption(this)">
            <input type="checkbox" name="q2" value="Reach potential / optimal health">
            Reach potential / optimal health
            <div class="option-open-input"><input type="text" placeholder="Describe..." onclick="event.stopPropagation()"></div>
          </label>
        </div>
      </div>

      <!-- Q3 -->
      <div class="question-block">
        <div class="q-label"><span class="q-num">3</span>Have we done a good job explaining the objective of your care plan? Do you understand why you are getting adjusted?</div>
        <div class="options-list">
          <label class="option-item" onclick="selectRadio(this,'q3')"><input type="radio" name="q3" value="Yes"> Yes</label>
          <label class="option-item" onclick="selectRadio(this,'q3')"><input type="radio" name="q3" value="No"> No</label>
        </div>
      </div>

      <!-- Q4 -->
      <div class="question-block">
        <div class="q-label"><span class="q-num">4</span>Has the doctor fully explained the cause of your problem? Do you understand your problem (Subluxation)?</div>
        <div class="options-list">
          <label class="option-item" onclick="selectRadio(this,'q4')"><input type="radio" name="q4" value="Yes"> Yes</label>
          <label class="option-item" onclick="selectRadio(this,'q4')"><input type="radio" name="q4" value="No"> No</label>
        </div>
      </div>

      <!-- Q5 -->
      <div class="question-block">
        <div class="q-label"><span class="q-num">5</span>Do you understand the difference between your symptom and the problem (Subluxation)?</div>
        <div class="options-list">
          <label class="option-item" onclick="selectRadio(this,'q5')"><input type="radio" name="q5" value="Yes"> Yes</label>
          <label class="option-item" onclick="selectRadio(this,'q5')"><input type="radio" name="q5" value="No"> No</label>
        </div>
      </div>

      <!-- Q6 -->
      <div class="question-block">
        <div class="q-label"><span class="q-num">6</span>What Phase of Subluxation are you in?</div>
        <div class="options-list">
          <label class="option-item" onclick="selectRadio(this,'q6')"><input type="radio" name="q6" value="Phase 1"> Phase 1</label>
          <label class="option-item" onclick="selectRadio(this,'q6')"><input type="radio" name="q6" value="Phase 2"> Phase 2</label>
          <label class="option-item" onclick="selectRadio(this,'q6')"><input type="radio" name="q6" value="Phase 3"> Phase 3</label>
        </div>
      </div>

      <!-- Q7 -->
      <div class="question-block">
        <div class="q-label"><span class="q-num">7</span>How long has this problem been in your spine? (years)</div>
        <input type="number" id="q7years" min="0" max="99" placeholder="Enter number of years" style="max-width:220px;">
      </div>

      <!-- Q8 -->
      <div class="question-block">
        <div class="q-label"><span class="q-num">8</span>Do you know the 3 "Legs" of The 3 Legged Stool of Correction? Select all that you know:</div>
        <div class="options-list">
          <label class="option-item" onclick="toggleOption(this)"><input type="checkbox" name="q8" value="Breaking Bad Habits"> Breaking Bad Habits</label>
          <label class="option-item" onclick="toggleOption(this)"><input type="checkbox" name="q8" value="Exercise"> Exercise</label>
          <label class="option-item" onclick="toggleOption(this)"><input type="checkbox" name="q8" value="Nutrition"> Nutrition</label>
          <label class="option-item" onclick="toggleOption(this)"><input type="checkbox" name="q8" value="Adjustments"> Adjustments</label>
          <label class="option-item" onclick="toggleOption(this)"><input type="checkbox" name="q8" value="Sleep Patterns"> Sleep Patterns</label>
        </div>
      </div>

      <!-- Q9 -->
      <div class="question-block">
        <div class="q-label"><span class="q-num">9</span>Do you understand the doctor's recommendation for your care?</div>
        <div class="options-list">
          <label class="option-item" onclick="selectRadio(this,'q9')"><input type="radio" name="q9" value="Yes"> Yes</label>
          <label class="option-item" onclick="selectRadio(this,'q9')"><input type="radio" name="q9" value="No"> No</label>
        </div>
      </div>

      <!-- Q10 -->
      <div class="question-block">
        <div class="q-label"><span class="q-num">10</span>How often per week are you currently scheduled to be adjusted?</div>
        <input type="number" id="q10freq" min="1" max="7" placeholder="Times per week" style="max-width:200px;">
      </div>

      <!-- Q11 -->
      <div class="question-block">
        <div class="q-label"><span class="q-num">11</span>Have you been following the doctor's recommendations and keeping your adjustment schedule?</div>
        <div class="options-list">
          <label class="option-item" onclick="selectRadio(this,'q11')"><input type="radio" name="q11" value="Yes"> Yes</label>
          <label class="option-item" onclick="selectRadio(this,'q11')"><input type="radio" name="q11" value="No"> No</label>
        </div>
      </div>

      <!-- Q12 -->
      <div class="question-block">
        <div class="q-label"><span class="q-num">12</span>How could we help you maximize your results and reach your goals?</div>
        <textarea id="q12text" class="notes-input" placeholder="Share your thoughts..."></textarea>
        <div id="q12print" class="notes-print"></div>
      </div>

      <!-- Q13 -->
      <div class="question-block">
        <div class="q-label"><span class="q-num">13</span>Have your family members had a Spine and Nerve System Check-up yet?</div>
        <div class="options-list">
