  function collectROM() {
    const cervMov  = ['Flexion','Extension','Left Lat Flex','Right Lat Flex','Left Rotation','Right Rotation'];
    const cervNorm = [50,60,45,45,80,80];
    const lumbMov  = ['Flexion','Extension','Left Lat Flex','Right Lat Flex','Left Rotation','Right Rotation'];
    const lumbNorm = [60,25,25,25,30,30];

    const rows = document.querySelectorAll('.rom-table tbody tr');
    let cerv = [], lumb = [], sec = '';
    rows.forEach(row => {
      const fc = row.querySelector('td');
      if (!fc) return;
      const t = fc.textContent.trim().toUpperCase();
      if (t === 'CERVICAL') { sec = 'C'; return; }
      if (t === 'LUMBAR')   { sec = 'L'; return; }
      const ins = row.querySelectorAll('input');
      if (ins.length >= 2) {
        const e = { movement: fc.textContent.trim(), deg: ins[0].value || '—', pain: ins[1].value || 'None' };
        if (sec === 'C') cerv.push(e);
        if (sec === 'L') lumb.push(e);
      }
    });

    const balL = document.getElementById('curBalLeft')?.value  || '—';
    const balR = document.getElementById('curBalRight')?.value || '—';

    let note = `PROGRESS EXAM 1 — ROM & EXAM RESULTS\n`;
    note += `Patient: ${contactName || '—'} | Email: ${contactEmail || '—'}\n`;
    note += `Date: ${new Date().toLocaleDateString('en-US')}\n\n`;
    note += `CERVICAL ROM\n${'─'.repeat(48)}\n`;
    note += `${'Movement'.padEnd(18)} ${'Normal'.padEnd(8)} ${'Patient'.padEnd(10)} Pain\n`;
    cerv.forEach((r,i) => { note += `${r.movement.padEnd(18)} ${String(cervNorm[i]+'°').padEnd(8)} ${String(r.deg+'°').padEnd(10)} ${r.pain}\n`; });
    note += `\nLUMBAR ROM\n${'─'.repeat(48)}\n`;
    note += `${'Movement'.padEnd(18)} ${'Normal'.padEnd(8)} ${'Patient'.padEnd(10)} Pain\n`;
    lumb.forEach((r,i) => { note += `${r.movement.padEnd(18)} ${String(lumbNorm[i]+'°').padEnd(8)} ${String(r.deg+'°').padEnd(10)} ${r.pain}\n`; });
    note += `\nBILATERAL BALANCES\nCurrent Balance: ${balL} / ${balR}\n`;

    const flags = [...document.querySelectorAll('.flag-check:checked')]
      .map(cb => cb.closest('.check-item')?.querySelector('label')?.textContent?.trim())
      .filter(Boolean);
    if (flags.length) { note += `\nFLAGS FOR DOCTOR\n`; flags.forEach(f => { note += `• ${f}\n`; }); }

    const caNotes = document.getElementById('caNotes')?.value?.trim();
    if (caNotes) { note += `\nCA NOTES\n${caNotes}\n`; }

    return { note, balL, balR, curBal: `${balL}/${balR}` };
  }

  function collectROMStructured() {
    const cervNorms = [50,60,45,45,80,80];
    const lumbNorms = [60,25,25,25,30,30];
    const rows = document.querySelectorAll('.rom-table tbody tr');
    let cerv = [], lumb = [], sec = '';

    rows.forEach(row => {
      const fc = row.querySelector('td');
      if (!fc) return;
      const t = fc.textContent.trim().toUpperCase();
      if (t === 'CERVICAL') { sec = 'C'; return; }
      if (t === 'LUMBAR')   { sec = 'L'; return; }
      const ins = row.querySelectorAll('input');
      if (ins.length >= 2) {
        const arr   = sec === 'C' ? cerv : lumb;
        const norms = sec === 'C' ? cervNorms : lumbNorms;
        arr.push({
          movement: fc.textContent.trim(),
          deg:  ins[0].value || '',
          pain: ins[1].value || 'None',
          norm: norms[arr.length]
        });
      }
    });

    const balL = document.getElementById('curBalLeft')?.value  || '—';
    const balR = document.getElementById('curBalRight')?.value || '—';

    let note = `PROGRESS EXAM 1 — ROM & EXAM RESULTS\nPatient: ${contactName||'—'}\nDate: ${new Date().toLocaleDateString('en-US')}\n\n`;
    note += `CERVICAL ROM\n`;
    cerv.forEach(r => { note += `  ${r.movement}: ${r.deg||'—'}° (Normal ${r.norm}°) Pain: ${r.pain}\n`; });
    note += `\nLUMBAR ROM\n`;
    lumb.forEach(r => { note += `  ${r.movement}: ${r.deg||'—'}° (Normal ${r.norm}°) Pain: ${r.pain}\n`; });
    note += `\nBilateral Balance: L ${balL} / R ${balR}`;

    const flags = [...document.querySelectorAll('.flag-check:checked')]
      .map(cb => cb.closest('.check-item')?.querySelector('label')?.textContent?.trim())
      .filter(Boolean);
    if (flags.length) { note += `\n\nFLAGS:\n`; flags.forEach(f => { note += `• ${f}\n`; }); }

    const caNotes = document.getElementById('caNotes')?.value?.trim();
    if (caNotes) note += `\nCA Notes: ${caNotes}`;

    return { cerv, lumb, balL, balR, curBal: `${balL}/${balR}`, note };
  }


  // ── Webhook ──
  async function sendToGHL(payload) {
    try {
      const res = await fetch(WEBHOOK, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      return res.ok;
