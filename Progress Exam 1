  // ── PDF Builder (pure jsPDF, no html2canvas) ──

  const PDF = {
    GOLD:       [193, 179, 125],
    DARK:       [31,  45,  61],
    MID:        [80,  80,  80],
    LIGHT:      [130, 130, 130],
    BG:         [248, 248, 248],
    WHITE:      [255, 255, 255],
    RED:        [180, 40,  40],
    GREEN:      [30,  120, 60],
    L:          14,   // left margin
    R:          196,  // right edge
    W:          182,  // usable width
    PH:         297,  // page height
    lineH:      6,
  };

  function newDoc() {
    const { jsPDF } = window.jspdf;
    return new jsPDF('p', 'mm', 'a4');
  }

  function pdfHeader(doc, title, subtitle, y) {
    // Gold bar top
    doc.setFillColor(...PDF.GOLD);
    doc.rect(PDF.L, y, PDF.W, 1.2, 'F');
    y += 5;

    // Logo placeholder text (WAC branding)
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(10);
    doc.setTextColor(...PDF.LIGHT);
    doc.text('WELL ADJUSTED CHIROPRACTIC', PDF.L, y);

    // Right side: date
    const dateStr = new Date().toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' });
    doc.setFont('helvetica', 'normal');
    doc.setFontSize(8);
    doc.text(dateStr, PDF.R, y, { align: 'right' });
    y += 5;

    // Title
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(16);
    doc.setTextColor(...PDF.DARK);
    doc.text(title, PDF.L, y);
    y += 6;

    // Subtitle
    if (subtitle) {
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(9);
      doc.setTextColor(...PDF.MID);
      doc.text(subtitle, PDF.L, y);
      y += 5;
    }

    // Gold divider
    doc.setFillColor(...PDF.GOLD);
    doc.rect(PDF.L, y, PDF.W, 0.6, 'F');
    y += 6;
    return y;
  }

  function pdfFooter(doc, pageNum, total) {
    doc.setFont('helvetica', 'normal');
    doc.setFontSize(7);
    doc.setTextColor(...PDF.LIGHT);
    doc.text(`Page ${pageNum} of ${total}  •  Well Adjusted Chiropractic  •  Confidential`, PDF.L, PDF.PH - 6);
    doc.setDrawColor(...PDF.GOLD);
    doc.setLineWidth(0.4);
    doc.line(PDF.L, PDF.PH - 9, PDF.R, PDF.PH - 9);
  }

  function sectionHeading(doc, text, y) {
    doc.setFillColor(...PDF.BG);
    doc.roundedRect(PDF.L, y - 4, PDF.W, 7, 1, 1, 'F');
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(8);
    doc.setTextColor(...PDF.GOLD);
    doc.text(text.toUpperCase(), PDF.L + 3, y);
    return y + 6;
  }

  function qRow(doc, num, question, answer, y, flag) {
    const lineColor = flag ? PDF.RED : PDF.GOLD;
    doc.setDrawColor(...lineColor);
    doc.setLineWidth(0.4);
    doc.line(PDF.L, y, PDF.L, y + 10);

    doc.setFillColor(flag ? 255 : PDF.BG[0], flag ? 245 : PDF.BG[1], flag ? 245 : PDF.BG[2]);
    doc.roundedRect(PDF.L + 2, y - 1, PDF.W - 2, 11, 1, 1, 'F');

    doc.setFont('helvetica', 'bold');
    doc.setFontSize(7);
    doc.setTextColor(...PDF.GOLD);
    doc.text(`Q${num}`, PDF.L + 4, y + 4);

    doc.setFont('helvetica', 'normal');
    doc.setFontSize(8);
    doc.setTextColor(...PDF.MID);
    const qLines = doc.splitTextToSize(question, 120);
    doc.text(qLines, PDF.L + 12, y + 3.5);

    doc.setFont('helvetica', 'bold');
    doc.setFontSize(8);
    doc.setTextColor(flag ? PDF.RED[0] : PDF.DARK[0], flag ? PDF.RED[1] : PDF.DARK[1], flag ? PDF.RED[2] : PDF.DARK[2]);
    doc.text(String(answer || '—'), PDF.R - 2, y + 4, { align: 'right' });

    return y + 13;
  }

  function romTable(doc, rows, label, y) {
    y = sectionHeading(doc, label + ' Range of Motion', y);

    // Table header
    doc.setFillColor(...PDF.DARK);
    doc.rect(PDF.L, y, PDF.W, 6, 'F');
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(7.5);
    doc.setTextColor(...PDF.WHITE);
    doc.text('Movement',          PDF.L + 3, y + 4);
    doc.text('Normal',            PDF.L + 70, y + 4, { align: 'center' });
    doc.text('Patient',           PDF.L + 100, y + 4, { align: 'center' });
    doc.text('Pain / Note',       PDF.L + 145, y + 4, { align: 'center' });
    y += 6;

    rows.forEach((r, i) => {
      const bg = i % 2 === 0 ? PDF.WHITE : PDF.BG;
      doc.setFillColor(...bg);
      doc.rect(PDF.L, y, PDF.W, 6, 'F');

      const belowNorm = parseFloat(r.deg) < parseFloat(r.norm);
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(8);
      doc.setTextColor(...PDF.DARK);
      doc.text(r.movement, PDF.L + 3, y + 4);

      doc.setTextColor(...PDF.MID);
      doc.text(r.norm + '°', PDF.L + 70, y + 4, { align: 'center' });

      doc.setFont('helvetica', 'bold');
      doc.setTextColor(belowNorm ? PDF.RED[0] : PDF.GREEN[0], belowNorm ? PDF.RED[1] : PDF.GREEN[1], belowNorm ? PDF.RED[2] : PDF.GREEN[2]);
      doc.text(r.deg ? r.deg + '°' : '—', PDF.L + 100, y + 4, { align: 'center' });

      doc.setFont('helvetica', 'normal');
      doc.setTextColor(...PDF.MID);
      doc.text(r.pain || 'None', PDF.L + 145, y + 4, { align: 'center' });
      y += 6;
    });

    return y + 4;
  }

  function patientInfoBar(doc, y) {
    doc.setFillColor(...PDF.BG);
    doc.roundedRect(PDF.L, y, PDF.W, 14, 2, 2, 'F');
    doc.setDrawColor(...PDF.GOLD);
    doc.setLineWidth(0.3);
    doc.roundedRect(PDF.L, y, PDF.W, 14, 2, 2, 'S');

    const urlParams = new URLSearchParams(window.location.search);
    const complaint = urlParams.get('complaint') || '—';
    const phase     = urlParams.get('phase')     || '—';
    const cpStart   = urlParams.get('cp_start')  || '—';
    const provider  = urlParams.get('provider')  || '—';

    const cols = [
      { label: 'Patient',          val: contactName  || '—' },
      { label: 'Chief Complaint',  val: complaint },
      { label: 'Phase',            val: phase },
      { label: 'Care Plan Start',  val: cpStart },
      { label: 'Provider',         val: provider },
    ];

    const colW = PDF.W / cols.length;
    cols.forEach((c, i) => {
      const x = PDF.L + i * colW + 3;
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(6.5);
      doc.setTextColor(...PDF.LIGHT);
      doc.text(c.label.toUpperCase(), x, y + 5);
      doc.setFont('helvetica', 'bold');
      doc.setFontSize(8);
      doc.setTextColor(...PDF.DARK);
      doc.text(String(c.val), x, y + 11);
    });

    return y + 18;
  }

