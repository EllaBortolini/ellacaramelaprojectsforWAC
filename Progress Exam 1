<script>
  // ── Config ──
  const WEBHOOK = 'https://services.leadconnectorhq.com/hooks/oej0L0NKPdaUHsXpkfht/webhook-trigger/918b97a5-9a51-4d4a-9a93-f930c6b7be79';

  // ── URL Autofill ──
  let contactName = '', contactEmail = '';

  function handleUrlAutofill() {
    const p = new URLSearchParams(window.location.search);
    contactName  = p.get('name')      || p.get('contact_name')  || '';
    contactEmail = p.get('email')     || p.get('contact_email') || '';
    const cc     = p.get('complaint') || p.get('chief_complaint') || '';
    const phase  = p.get('phase')     || p.get('degeneration_phase') || '';
    const ogbal  = p.get('og_balance')|| p.get('original_balance') || '';
    const cpstart= p.get('cp_start')  || p.get('care_plan_start') || '';
    const provider=p.get('provider')  || p.get('provider_name') || '';
    const today  = new Date().toLocaleDateString('en-US');

    // Phase 1 header
    setText('p1Name', contactName || 'Patient');
    setText('p1Date', today);

    // Phase 2 header + cards
    setText('p2Name',     contactName || 'Patient');
    setText('p2Date',     today);
    setText('p2Provider', provider || '—');
    setText('caCC',       cc       || '—');
    setText('caPhase',    phase    || '—');
    setText('caOGBal',    ogbal    || '—');
    if (cpstart) {
      const d = new Date(cpstart);
      setText('caCPStart', isNaN(d) ? cpstart : d.toLocaleDateString('en-US'));
    } else {
      setText('caCPStart', '—');
    }

    // Clear unresolved GHL tokens
    ['p1Name','p2Name','p2Provider','caCC','caPhase','caOGBal','caCPStart'].forEach(id => {
      const el = document.getElementById(id);
      if (el && /\{\{.*\}\}/.test(el.textContent)) el.textContent = '—';
    });
  }

  function setText(id, val) {
    const el = document.getElementById(id);
    if (el) el.textContent = val;
  }

  // ── Star Rating ──
  function selectStar(val) {
    document.getElementById('q1Stars').value = val;
    document.querySelectorAll('.star-btn').forEach(btn => {
      btn.classList.toggle('selected', parseInt(btn.dataset.val) <= val);
    });
  }

  // ── Option toggles ──
  function selectRadio(item, name) {
    document.querySelectorAll(`[name="${name}"]`).forEach(r => {
      r.closest('.option-item')?.classList.remove('selected');
    });
    item.classList.add('selected');
    const radio = item.querySelector('input[type="radio"]');
    if (radio) radio.checked = true;

    // Auto-flag CA section
    autoFlag(name);
  }

  function toggleOption(item) {
    item.classList.toggle('selected');
    const cb = item.querySelector('input[type="checkbox"]');
    if (cb) cb.checked = !cb.checked;
  }

  // ── Auto-flag CA based on patient answers ──
  function autoFlag(name) {
    const flagMap = { q3: 'flagQ3', q4: 'flagQ4', q5: 'flagQ5', q9: 'flagQ9', q11: 'flagQ11' };
    if (!flagMap[name]) return;
    const selected = document.querySelector(`[name="${name}"]:checked`);
    if (!selected) return;
    const flagItem = document.getElementById(flagMap[name]);
    if (!flagItem) return;
    const isNo = selected.value === 'No';
    const cb   = flagItem.querySelector('input[type="checkbox"]');
    if (cb) cb.checked = isNo;
    flagItem.classList.toggle('flagged', isNo);
  }

  // ── Phase navigation ──
  // ── Phase navigation ──
  function advanceToReview() {
    buildReviewPage();
    document.body.classList.remove('ca-phase');
    document.body.classList.add('review-phase');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function advanceToCA() {
    document.body.classList.remove('review-phase');
    document.body.classList.add('ca-phase');
    window.scrollTo({ top: 0, behavior: 'smooth' });
    updateProgress();
  }

  function backToPatient() {
    document.body.classList.remove('ca-phase', 'review-phase');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ── Build review page from patient answers ──
  function buildReviewPage() {
    const urlParams = new URLSearchParams(window.location.search);

    // Populate header
    const today = new Date().toLocaleDateString('en-US', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
    const rvName = document.getElementById('rv_name');
    const rvDate = document.getElementById('rv_date');
    if (rvName) rvName.textContent = contactName || '—';
    if (rvDate) rvDate.textContent = today;

    // Collect answers
    const stars   = document.getElementById('q1Stars')?.value || '0';
    const q2vals  = [...document.querySelectorAll('[name="q2"]:checked')].map(c => c.value).join(', ') || '—';
    const q3      = document.querySelector('[name="q3"]:checked')?.value  || '—';
    const q4      = document.querySelector('[name="q4"]:checked')?.value  || '—';
    const q5      = document.querySelector('[name="q5"]:checked')?.value  || '—';
    const q6      = document.querySelector('[name="q6"]:checked')?.value  || '—';
    const q7      = document.getElementById('q7years')?.value             || '—';
    const q8vals  = [...document.querySelectorAll('[name="q8"]:checked')].map(c => c.value).join(', ') || '—';
    const q9      = document.querySelector('[name="q9"]:checked')?.value  || '—';
    const q10     = document.getElementById('q10freq')?.value             || '—';
    const q11     = document.querySelector('[name="q11"]:checked')?.value || '—';
    const q12     = document.getElementById('q12text')?.value?.trim()     || '—';
    const q13     = document.querySelector('[name="q13"]:checked')?.value || '—';
    const q14vals = [...document.querySelectorAll('[name="q14"]:checked')].map(c => c.value).join(', ') || '—';

    // ── Flag banner ──
    const flagDefs = [
      { q: 'Q3 — Have we explained the objective of your care plan?', ans: q3 },
      { q: 'Q4 — Has the doctor explained the cause of your problem (Subluxation)?', ans: q4 },
      { q: 'Q5 — Do you understand the difference between your symptom and the problem?', ans: q5 },
      { q: "Q9 — Do you understand the doctor's recommendation for your care?", ans: q9 },
      { q: "Q11 — Have you been following the doctor's recommendations and keeping your schedule?", ans: q11 },
    ].filter(f => f.ans === 'No');

    const flagBanner = document.getElementById('rv_flagBanner');
    const flagList   = document.getElementById('rv_flagList');
    if (flagDefs.length > 0) {
      flagList.innerHTML = flagDefs.map(f =>
        `<div class="flag-row"><span class="flag-icon">⚑</span><span><strong>No</strong> — ${f.q}</span></div>`
      ).join('');
      flagBanner.style.display = 'block';
    } else {
      flagBanner.style.display = 'none';
    }

    // ── Google review banner ──
    const gBanner = document.getElementById('rv_googleBanner');
    if (gBanner) gBanner.style.display = parseInt(stars) >= 5 ? 'flex' : 'none';

    // ── Summary grid (key metrics) ──
    const starDisplay = '★'.repeat(parseInt(stars)||0) + '☆'.repeat(5-(parseInt(stars)||0));
    const grid = document.getElementById('rv_grid');
    if (grid) {
      grid.innerHTML = [
        { label: 'Experience Rating', val: `${starDisplay} (${stars}/5)`, flag: false },
        { label: 'Phase of Subluxation', val: q6, flag: false },
        { label: 'Years with Problem', val: q7 !== '—' ? q7 + ' years' : '—', flag: false },
        { label: 'Adjustment Frequency', val: q10 !== '—' ? q10 + 'x / week' : '—', flag: false },
        { label: 'Following Schedule', val: q11, flag: q11 === 'No' },
        { label: 'Family Check-up Interest', val: q13, flag: false },
      ].map(item => `
        <div>
          <div class="review-q">${item.label}</div>
          <div class="review-a ${item.flag ? 'flagged-ans' : ''}">${item.val}</div>
        </div>
      `).join('');
    }

    // ── All answers ──
    const allAnswers = document.getElementById('rv_allAnswers');
    if (allAnswers) {
      const rows = [
        { n:'Q2',  label:'Health Goals',                                              val: q2vals, flag: false },
        { n:'Q3',  label:'Care plan objective explained?',                            val: q3,     flag: q3  === 'No' },
